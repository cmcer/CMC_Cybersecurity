---
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations, localePath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="cta-band-wrap container-x">
  <div class="cta-band glass reveal">
    <div class="cta-band__grid-overlay grid-overlay" aria-hidden="true"></div>
    <div class="cta-band__content">
      <span class="eyebrow">{t('tag.brand')}</span>
      <h2 class="cta-band__title">{t('section.cta.title')}</h2>
      <p class="cta-band__sub">{t('section.cta.sub')}</p>
      <div class="cta-band__actions">
        <a href={localePath('/contact', lang)} class="btn btn-primary">{t('cta.contact')} <Icon name="arrow-right" size={18} /></a>
        <a href={localePath('/services', lang)} class="btn btn-ghost">{t('cta.explore')}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band-wrap { margin-top: 5rem; }
  .cta-band {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    padding: clamp(2.5rem, 1rem + 6vw, 4.5rem);
    text-align: center;
    border: 1px solid rgba(10, 145, 210, 0.22);
  }
  .cta-band::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(600px 300px at 20% 0%, rgba(10, 145, 210, 0.18), transparent 60%),
      radial-gradient(600px 300px at 80% 100%, rgba(24, 200, 230, 0.14), transparent 60%);
    pointer-events: none;
  }
  .cta-band__grid-overlay { position: absolute; inset: 0; opacity: 0.4; }
  .cta-band__content { position: relative; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .cta-band__title { font-size: clamp(1.7rem, 1rem + 3vw, 2.7rem); max-width: 22ch; }
  .cta-band__sub { color: var(--color-fg-soft); max-width: 52ch; }
  .cta-band__actions { display: flex; flex-wrap: wrap; gap: 0.85rem; justify-content: center; margin-top: 0.75rem; }
</style>
