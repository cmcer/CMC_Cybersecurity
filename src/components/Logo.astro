---
import { getLangFromUrl, localePath, withBase } from '../i18n/utils';

interface Props { class?: string; }
const { class: className = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---
<a href={localePath('/', lang)} class={`logo ${className}`} aria-label="CMC Cyber Security — Home">
  <img
    src={withBase('/images/logo/cmccs-logo-horizontal-white.svg')}
    alt="CMC Cyber Security"
    width="254"
    height="39"
    class="logo__img"
  />
</a>

<style>
  .logo { display: inline-flex; align-items: center; }
  .logo__img {
    height: 30px;
    width: auto;
    display: block;
  }

  @media (min-width: 640px) {
    .logo__img { height: 34px; }
  }
</style>
