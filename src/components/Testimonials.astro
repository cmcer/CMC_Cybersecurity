---
import Icon from './Icon.astro';
import SectionHeading from './SectionHeading.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getTestimonials } from '../data/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const items = getTestimonials(lang);
const initials = (n: string) => n.split(' ').slice(-2).map((p) => p[0]).join('');
---
<section class="section container-x">
  <SectionHeading eyebrow={t('section.testimonials.eyebrow')} title={t('section.testimonials.title')} />
  <div class="tst-grid">
    {items.map((it, i) => (
      <figure class="tst-card surface-card lift reveal" style={`--reveal-delay:${(i % 3) * 100}ms`}>
        <span class="tst-card__quote" aria-hidden="true">&ldquo;</span>
        <blockquote class="tst-card__text">{it.quote}</blockquote>
        <figcaption class="tst-card__person">
          <span class="tst-card__avatar">{initials(it.name)}</span>
          <span class="tst-card__meta">
            <strong>{it.name}</strong>
            <span>{it.role} · {it.company}</span>
          </span>
          <span class="tst-card__stars" aria-label="5 / 5">
            {Array.from({ length: 5 }).map(() => <Icon name="sparkles" size={14} />)}
          </span>
        </figcaption>
      </figure>
    ))}
  </div>
</section>

<style>
  .section { padding-block: 3.5rem; }
  .tst-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-top: 2.75rem; }
  .tst-card { position: relative; padding: 2rem 1.75rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .tst-card__quote { font-size: 3.5rem; line-height: 0.6; color: var(--color-primary); font-family: var(--font-display); opacity: 0.5; }
  .tst-card__text { color: var(--color-fg); font-size: 1rem; line-height: 1.6; flex: 1; }
  .tst-card__person { display: flex; align-items: center; gap: 0.85rem; }
  .tst-card__avatar {
    flex: none; display: grid; place-items: center;
    width: 44px; height: 44px; border-radius: 50%;
    font-weight: 700; font-size: 0.9rem; color: #04243f;
    background: var(--grad-brand);
  }
  .tst-card__meta { display: flex; flex-direction: column; line-height: 1.2; }
  .tst-card__meta strong { font-size: 0.95rem; }
  .tst-card__meta span { font-size: 0.82rem; color: var(--color-fg-muted); }
  .tst-card__stars { margin-left: auto; display: inline-flex; gap: 1px; color: var(--color-primary); }

  @media (min-width: 860px) { .tst-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
