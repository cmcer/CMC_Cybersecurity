---
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations, localePath, withBase } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="data-banner-wrap container-x">
  <div class="data-banner reveal">
    <img src={withBase('/images/solutions-banner.jpg')} alt="" class="data-banner__bg" loading="lazy" decoding="async" aria-hidden="true" />
    <span class="data-banner__grid grid-overlay" aria-hidden="true"></span>
    <span class="data-banner__glow" aria-hidden="true"></span>
    <div class="data-banner__content">
      <Icon name="lock" size={34} class="data-banner__lock" />
      <h2 class="data-banner__title">{t('section.data.title')}</h2>
      <p class="data-banner__sub">{t('section.data.sub')}</p>
      <a href={localePath('/about', lang)} class="btn btn-primary">{t('cta.discover')} <Icon name="arrow-right" size={18} /></a>
    </div>
  </div>
</section>

<style>
  .data-banner-wrap { margin-top: 4rem; }
  .data-banner {
    position: relative; overflow: hidden;
    border-radius: var(--radius-xl);
    padding: clamp(2.5rem, 1rem + 6vw, 4.5rem);
    border: 1px solid var(--color-line-strong);
    background: linear-gradient(150deg, var(--color-surface-2), #061018);
  }
  .data-banner__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.32; }
  .data-banner::after { content: ''; position: absolute; inset: 0; background: linear-gradient(110deg, rgba(5, 19, 34, 0.92) 35%, rgba(5, 19, 34, 0.55)); }
  .data-banner__grid { position: absolute; inset: 0; opacity: 0.4; }
  .data-banner__glow { position: absolute; left: -10%; bottom: -40%; width: 380px; height: 380px; background: radial-gradient(circle, rgba(10, 145, 210, 0.2), transparent 70%); }
  .data-banner__content { position: relative; z-index: 2; max-width: 60ch; display: flex; flex-direction: column; align-items: flex-start; gap: 1rem; }
  .data-banner__lock { color: var(--color-primary-bright); }
  .data-banner__title { font-size: clamp(1.7rem, 1rem + 3vw, 2.6rem); max-width: 20ch; }
  .data-banner__sub { color: var(--color-fg-soft); font-size: 1.05rem; }
  .data-banner__content .btn { margin-top: 0.75rem; }
</style>
