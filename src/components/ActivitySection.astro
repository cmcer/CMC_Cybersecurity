---
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations, withBase } from '../i18n/utils';
import { getActivityCards } from '../data/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cards = getActivityCards(lang);
const imgs = ['/images/service-1.jpg', '/images/threat-intel.jpg', '/images/service-2.jpg'].map(withBase);
---
<section class="activity">
  <span class="activity__grid grid-overlay" aria-hidden="true"></span>
  <div class="container-x activity__inner">
    <div class="activity__head reveal">
      <span class="eyebrow">{t('section.activity.eyebrow')}</span>
      <h2 class="activity__title">{t('section.activity.title')}</h2>
      <p class="activity__sub">{t('section.activity.sub')}</p>
    </div>

    <div class="activity__grid-cards">
      {cards.map((c, i) => (
        <article
          class:list={['act-card reveal', c.highlight ? 'act-card--hl' : '']}
          style={`--reveal-delay:${i * 110}ms`}
        >
          <div class="act-card__media">
            <img src={imgs[i % imgs.length]} alt={c.title} class="act-card__photo" width="440" height="240" loading="lazy" decoding="async" />
          </div>
          <div class="act-card__body">
            <h3 class="act-card__title">{c.title}</h3>
            <p class="act-card__sub">{c.sub}</p>
            <ul class="act-card__list">
              {c.items.map((it) => (
                <li><Icon name="check" size={15} /> <span>{it}</span></li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .activity { position: relative; margin-top: 4rem; padding-block: 4.5rem; background: linear-gradient(180deg, var(--color-bg-soft), #061119 60%, var(--color-bg-soft)); border-block: 1px solid var(--color-line); overflow: hidden; }
  .activity > .activity__grid { position: absolute; inset: 0; opacity: 0.4; }
  .activity__inner { position: relative; }
  .activity__head { max-width: 60ch; margin: 0 auto 3rem; text-align: center; display: flex; flex-direction: column; gap: 0.85rem; }
  .activity__title { font-size: clamp(1.7rem, 1rem + 2.6vw, 2.5rem); }
  .activity__sub { color: var(--color-fg-soft); }

  .activity__grid-cards { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }

  .act-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: linear-gradient(165deg, var(--color-surface), var(--color-bg-soft));
    border: 1px solid var(--color-line);
    transition: transform 0.4s var(--ease-out-expo), border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .act-card:hover { transform: translateY(-6px); border-color: rgba(10, 145, 210, 0.4); box-shadow: 0 24px 60px -28px rgba(10, 145, 210, 0.4); }
  .act-card--hl { border-color: rgba(10, 145, 210, 0.5); box-shadow: 0 24px 60px -30px rgba(10, 145, 210, 0.55); }

  .act-card__media {
    position: relative; height: 170px; display: grid; place-items: center;
    border-bottom: 1px solid var(--color-line); overflow: hidden;
  }
  .act-card__photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease-out-expo); }
  .act-card:hover .act-card__photo { transform: scale(1.06); }
  .act-card__media::after { content: ''; position: absolute; inset: 0; background: linear-gradient(160deg, rgba(10, 145, 210, 0.45), rgba(5, 19, 34, 0.78)); }
  .act-card--hl .act-card__media::after { background: linear-gradient(160deg, rgba(10, 145, 210, 0.55), rgba(24, 200, 230, 0.5)); }

  .act-card__body { padding: 1.5rem; }
  .act-card__title { font-size: 1.2rem; }
  .act-card__sub { color: var(--color-fg-soft); font-size: 0.9rem; margin-top: 0.25rem; }
  .act-card__list { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; margin-top: 1.1rem; padding-top: 1.1rem; border-top: 1px solid var(--color-line); }
  .act-card__list li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; color: var(--color-fg-soft); }
  .act-card__list :global(svg) { color: var(--color-primary); flex: none; }

  @media (min-width: 860px) { .activity__grid-cards { grid-template-columns: repeat(3, 1fr); } }
</style>
