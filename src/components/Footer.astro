---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations, localePath } from '../i18n/utils';
import { contactInfo, getServices } from '../data/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const services = getServices(lang).slice(0, 5);
const year = 2026;

const supportLinks = [
  { key: 'cta.support', path: '/contact' },
  { key: 'nav.contact', path: '/contact' },
  { key: 'section.support.title', path: '/contact' },
  { key: 'nav.news', path: '/news' },
] as const;

const companyLinks = [
  { key: 'nav.about', path: '/about' },
  { key: 'nav.solutions', path: '/solutions' },
  { key: 'nav.careers', path: '/careers' },
  { key: 'nav.news', path: '/news' },
] as const;
---
<footer class="site-footer">
  <!-- Newsletter -->
  <div class="container-x">
    <div class="newsletter reveal">
      <div class="newsletter__text">
        <h3 class="newsletter__title">{t('newsletter.title')}</h3>
        <p class="newsletter__sub">{t('newsletter.sub')}</p>
      </div>
      <form class="newsletter__form" data-newsletter novalidate>
        <input type="email" name="email" required placeholder={t('newsletter.placeholder')} aria-label={t('newsletter.placeholder')} />
        <button type="submit" class="btn btn-primary">{t('cta.subscribe')} <Icon name="arrow-right" size={16} /></button>
      </form>
    </div>
  </div>

  <div class="container-x site-footer__grid">
    <div class="site-footer__brand">
      <Logo />
      <p class="site-footer__tag">{t('footer.tagline')}</p>
      <div class="site-footer__contact">
        <a href={`tel:${contactInfo.hotline.replace(/\s/g, '')}`}><Icon name="phone" size={15} /> {contactInfo.hotline}</a>
        <a href={`mailto:${contactInfo.email}`}><Icon name="mail" size={15} /> {contactInfo.email}</a>
      </div>
      <div class="site-footer__social">
        <a href="#" aria-label="LinkedIn"><Icon name="linkedin" size={18} /></a>
        <a href="#" aria-label="Facebook"><Icon name="facebook" size={18} /></a>
        <a href="#" aria-label="YouTube"><Icon name="youtube" size={18} /></a>
      </div>
    </div>

    <div class="site-footer__col">
      <h4>{t('footer.services')}</h4>
      <ul>
        {services.map((s) => (<li><a href={localePath('/services', lang)}>{s.title}</a></li>))}
      </ul>
    </div>

    <div class="site-footer__col">
      <h4>{t('footer.support')}</h4>
      <ul>
        {supportLinks.map((c) => (<li><a href={localePath(c.path, lang)}>{t(c.key as any)}</a></li>))}
      </ul>
    </div>

    <div class="site-footer__col">
      <h4>{t('footer.company')}</h4>
      <ul>
        {companyLinks.map((c) => (<li><a href={localePath(c.path, lang)}>{t(c.key as any)}</a></li>))}
      </ul>
    </div>
  </div>

  <div class="container-x site-footer__bottom">
    <p>© {year} {t('footer.rights')}</p>
    <p class="site-footer__note">{t('footer.note')}</p>
  </div>
</footer>

<style>
  .site-footer { margin-top: 5rem; }

  .newsletter {
    display: grid; grid-template-columns: 1fr; gap: 1.5rem;
    padding: clamp(1.75rem, 1rem + 3vw, 2.75rem);
    border-radius: var(--radius-xl);
    background: linear-gradient(150deg, var(--color-surface-2), #061018);
    border: 1px solid var(--color-line-strong);
    align-items: center;
  }
  .newsletter__title { font-size: clamp(1.4rem, 1rem + 1.6vw, 1.9rem); }
  .newsletter__sub { color: var(--color-fg-soft); margin-top: 0.4rem; }
  .newsletter__form { display: flex; flex-direction: column; gap: 0.6rem; }
  .newsletter__form input {
    min-height: 50px; padding: 0.85rem 1.1rem; border-radius: 7px;
    background: rgba(5, 12, 18, 0.6); border: 1px solid var(--color-line-strong);
    color: var(--color-fg); font-family: inherit; font-size: 0.95rem;
  }
  .newsletter__form input:focus { outline: none; border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(10, 145, 210, 0.16); }
  .newsletter__form .btn { white-space: nowrap; }

  .site-footer__grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; padding-block: 3.5rem 3rem; }
  .site-footer__tag { color: var(--color-fg-soft); margin-top: 1rem; max-width: 32ch; font-size: 0.95rem; }
  .site-footer__contact { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1.1rem; }
  .site-footer__contact a { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--color-fg-soft); font-size: 0.9rem; transition: color 0.2s ease; }
  .site-footer__contact a:hover { color: var(--color-primary); }
  .site-footer__contact :global(svg) { color: var(--color-primary); }
  .site-footer__social { display: flex; gap: 0.6rem; margin-top: 1.25rem; }
  .site-footer__social a {
    display: grid; place-items: center; width: 40px; height: 40px; border-radius: 6px;
    border: 1px solid var(--color-line-strong); color: var(--color-fg-soft);
    transition: color 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }
  .site-footer__social a:hover { color: var(--color-primary); border-color: var(--color-primary); transform: translateY(-3px); }

  .site-footer__col h4 { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-fg-muted); margin-bottom: 1.1rem; }
  .site-footer__col ul { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
  .site-footer__col a { color: var(--color-fg-soft); font-size: 0.92rem; transition: color 0.2s ease; }
  .site-footer__col a:hover { color: var(--color-primary); }

  .site-footer__bottom {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding-block: 1.75rem; border-top: 1px solid var(--color-line);
    color: var(--color-fg-muted); font-size: 0.84rem;
  }
  .site-footer__note { opacity: 0.7; }

  @media (min-width: 680px) { .newsletter { grid-template-columns: 1.3fr 1fr; } .newsletter__form { flex-direction: row; } .newsletter__form input { flex: 1; } }
  @media (min-width: 720px) { .site-footer__grid { grid-template-columns: 1.6fr 1fr 1fr 1fr; } }
  @media (min-width: 1024px) { .site-footer__bottom { flex-direction: row; justify-content: space-between; align-items: center; } }
</style>

<script>
  const f = document.querySelector<HTMLFormElement>('[data-newsletter]');
  f?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = f.querySelector<HTMLInputElement>('input');
    if (input && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
      f.innerHTML = '<p style="color:var(--color-success);font-weight:600">✓ ' + (document.documentElement.lang === 'en' ? 'Subscribed! Thank you.' : 'Đã đăng ký! Cảm ơn bạn.') + '</p>';
    } else {
      input?.focus();
    }
  });
</script>
