---
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations, localePath } from '../i18n/utils';
import { getTrustItems } from '../data/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const items = getTrustItems(lang);
---
<section class="trustband-wrap container-x">
  <div class="trustband reveal">
    <div class="trustband__top">
      <h2 class="trustband__title">{t('section.trust.title')}</h2>
      <p class="trustband__sub">{t('section.trust.sub')}</p>
    </div>
    <div class="trustband__items">
      {items.map((it) => (
        <div class="trustband__item">
          <span class="trustband__icon"><Icon name={it.icon} size={26} /></span>
          <strong>{it.value}</strong>
          <span class="trustband__sub2">{it.sub}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trustband-wrap { margin-top: 4rem; }
  .trustband {
    position: relative; overflow: hidden;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, #0e8ecf 0%, #0066b8 55%, #094f92 100%);
    color: #ffffff;
    padding: clamp(2.5rem, 1rem + 5vw, 4rem);
    box-shadow: 0 40px 90px -40px rgba(10, 145, 210, 0.6);
  }
  .trustband__top { position: relative; text-align: center; max-width: 56ch; margin: 0 auto 3rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .trustband__title { font-size: clamp(1.7rem, 1rem + 3vw, 2.6rem); color: #ffffff; }
  .trustband__sub { color: rgba(255, 255, 255, 0.85); font-weight: 400; max-width: 46ch; }

  .trustband__items {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
  }
  .trustband__item {
    text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    padding-top: 0;
  }
  .trustband__icon {
    display: grid; place-items: center;
    width: 60px; height: 60px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    color: #ffffff;
    background: transparent;
    margin-bottom: 0.4rem;
  }
  .trustband__item strong { font-size: 1.05rem; font-weight: 700; color: #ffffff; }
  .trustband__sub2 { font-size: 0.86rem; color: rgba(255, 255, 255, 0.8); max-width: 30ch; }

  @media (min-width: 760px) {
    .trustband__items {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    .trustband__item {
      position: relative;
      padding-inline: 1.5rem;
    }
    .trustband__item:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0; top: 4px; bottom: 4px;
      width: 1px;
      background: rgba(255, 255, 255, 0.25);
    }
  }
</style>
