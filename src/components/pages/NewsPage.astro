---
import PageHero from '../PageHero.astro';
import Icon from '../Icon.astro';
import CtaBand from '../CtaBand.astro';
import { getLangFromUrl, useTranslations, withBase } from '../../i18n/utils';
import { getNews } from '../../data/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const news = getNews(lang);
const fmt = (d: string) =>
  new Date(d).toLocaleDateString(lang === 'vi' ? 'vi-VN' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const imgs = ['/images/news.jpg', '/images/threat-intel.jpg', '/images/life-3.jpg'].map(withBase);
---
<PageHero eyebrow={t('nav.news')} title={t('news.title')} sub={t('news.sub')} image="/images/news.jpg" />

<section class="section container-x">
  <div class="news-grid">
    {news.map((n, i) => (
      <article class="news-card surface-card lift reveal" style={`--reveal-delay:${(i % 3) * 90}ms`}>
        <div class="news-card__media">
          <img src={imgs[i % imgs.length]} alt={n.title} class="news-card__photo" width="440" height="220" loading="lazy" decoding="async" />
          <span class="news-card__tag chip">{n.tag}</span>
        </div>
        <div class="news-card__body">
          <time class="news-card__date">{fmt(n.date)}</time>
          <h3 class="news-card__title">{n.title}</h3>
          <p class="news-card__excerpt">{n.excerpt}</p>
          <a href="#" class="news-card__link">{t('news.readMore')} <Icon name="arrow-right" size={16} /></a>
        </div>
      </article>
    ))}
  </div>
</section>

<CtaBand />

<style>
  .section { padding-block: 3rem; }
  .news-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  .news-card { overflow: hidden; display: flex; flex-direction: column; }
  .news-card__media {
    position: relative;
    height: 180px;
    overflow: hidden;
    border-bottom: 1px solid var(--color-line);
  }
  .news-card__photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s var(--ease-out-expo); }
  .news-card:hover .news-card__photo { transform: scale(1.06); }
  .news-card__media::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(5, 19, 34, 0.1), rgba(5, 19, 34, 0.7)); }
  .news-card__tag { position: absolute; top: 1rem; left: 1rem; z-index: 1; color: var(--color-primary-bright); background: rgba(5, 19, 34, 0.7); backdrop-filter: blur(4px); }
  .news-card__body { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.6rem; flex: 1; }
  .news-card__date { font-family: var(--font-mono); font-size: 0.76rem; color: var(--color-fg-muted); }
  .news-card__title { font-size: 1.18rem; line-height: 1.3; }
  .news-card__excerpt { color: var(--color-fg-soft); font-size: 0.93rem; flex: 1; }
  .news-card__link { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--color-primary); font-weight: 600; font-size: 0.9rem; margin-top: 0.4rem; transition: gap 0.25s ease; }
  .news-card__link:hover { gap: 0.7rem; }
  @media (min-width: 640px) { .news-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .news-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
