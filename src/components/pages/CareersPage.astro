---
import PageHero from '../PageHero.astro';
import Icon from '../Icon.astro';
import SectionHeading from '../SectionHeading.astro';
import CtaBand from '../CtaBand.astro';
import { getLangFromUrl, useTranslations, localePath } from '../../i18n/utils';
import { getJobs, getValues } from '../../data/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const jobs = getJobs(lang);
const perks = getValues(lang);
---
<PageHero eyebrow={t('nav.careers')} title={t('careers.title')} sub={t('careers.sub')} image="/images/careers.jpg" />

<section class="section container-x">
  <div class="perks">
    {perks.map((p, i) => (
      <article class="perks__card glass reveal" style={`--reveal-delay:${(i % 4) * 80}ms`}>
        <span class="perks__icon"><Icon name={p.icon} size={22} /></span>
        <h4>{p.title}</h4>
        <p>{p.desc}</p>
      </article>
    ))}
  </div>
</section>

<section class="section container-x">
  <SectionHeading title={t('careers.openings')} align="left" />
  <div class="jobs mt">
    {jobs.map((j, i) => (
      <article class="job surface-card lift reveal" style={`--reveal-delay:${(i % 2) * 90}ms`}>
        <div class="job__main">
          <h3 class="job__title">{j.title}</h3>
          <div class="job__meta">
            <span><Icon name="map-pin" size={15} /> {j.location}</span>
            <span><Icon name="activity" size={15} /> {j.type}</span>
            <span><Icon name="award" size={15} /> {j.level}</span>
          </div>
        </div>
        <a href={localePath('/contact', lang)} class="btn btn-ghost job__apply">{t('cta.apply')} <Icon name="arrow-up-right" size={16} /></a>
      </article>
    ))}
  </div>
</section>

<CtaBand />

<style>
  .section { padding-block: 3rem; }
  .mt { margin-top: 2rem; }
  .perks { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .perks__card { border-radius: var(--radius-lg); padding: 1.5rem; display: flex; flex-direction: column; gap: 0.55rem; }
  .perks__icon { display: grid; place-items: center; width: 46px; height: 46px; border-radius: 7px; color: var(--color-primary-bright); background: rgba(10, 145, 210,0.1); border: 1px solid rgba(10, 145, 210,0.22); }
  .perks__card h4 { font-size: 1.1rem; }
  .perks__card p { color: var(--color-fg-soft); font-size: 0.9rem; }

  .jobs { display: flex; flex-direction: column; gap: 1rem; }
  .job { display: flex; flex-direction: column; gap: 1rem; padding: 1.5rem; }
  .job__title { font-size: 1.25rem; }
  .job__meta { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.6rem; color: var(--color-fg-muted); font-size: 0.88rem; }
  .job__meta span { display: inline-flex; align-items: center; gap: 0.4rem; }
  .job__meta :global(svg) { color: var(--color-primary); }
  .job__apply { align-self: flex-start; }

  @media (min-width: 640px) { .perks { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 980px) {
    .perks { grid-template-columns: repeat(4, 1fr); }
    .job { flex-direction: row; align-items: center; justify-content: space-between; }
    .job__apply { align-self: center; }
  }
</style>
