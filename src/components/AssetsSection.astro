---
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations, localePath, withBase } from '../i18n/utils';
import { getAssetFeatures } from '../data/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const features = getAssetFeatures(lang);
---
<section class="assets container-x">
  <div class="assets__head reveal">
    <div class="assets__photo">
      <img src={withBase('/images/about.jpg')} alt={lang === 'vi' ? 'Đội ngũ chuyên gia CMC Cyber Security' : 'CMC Cyber Security expert team'} width="520" height="340" loading="lazy" decoding="async" />
    </div>
    <span class="eyebrow">{t('section.assets.eyebrow')}</span>
    <h2 class="assets__title">{t('section.assets.title')}</h2>
    <p class="assets__sub">{t('section.assets.sub')}</p>
    <a href={localePath('/contact', lang)} class="btn btn-primary">{t('cta.getStarted')} <Icon name="arrow-right" size={18} /></a>
  </div>

  <div class="assets__grid">
    {features.map((f, i) => (
      <article class="assets__card glass lift reveal" style={`--reveal-delay:${(i % 2) * 100}ms`}>
        <span class="assets__icon"><Icon name={f.icon} size={22} /></span>
        <h3>{f.title}</h3>
        <p>{f.desc}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .assets { display: grid; grid-template-columns: 1fr; gap: 2.5rem; padding-block: 4rem; align-items: stretch; }
  .assets__head { display: flex; flex-direction: column; align-items: flex-start; gap: 1rem; max-width: 52ch; }
  .assets__photo { width: 100%; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--color-line); margin-bottom: 0.5rem; }
  .assets__photo img { width: 100%; height: 230px; object-fit: cover; display: block; }
  .assets__title { font-size: clamp(1.7rem, 1rem + 2.6vw, 2.5rem); }
  .assets__sub { color: var(--color-fg-soft); font-size: 1.05rem; }
  .assets__head .btn { margin-top: auto; }

  .assets__grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .assets__card {
    border-radius: var(--radius-lg); padding: 1.5rem;
    display: flex; flex-direction: column; justify-content: center; gap: 0.6rem;
    height: 100%;
  }
  .assets__icon {
    display: grid; place-items: center; width: 46px; height: 46px; border-radius: 7px;
    color: var(--color-primary-bright); background: rgba(10, 145, 210, 0.1); border: 1px solid rgba(10, 145, 210, 0.22);
    flex: none;
  }
  .assets__card h3 { font-size: 1.1rem; }
  .assets__card p { color: var(--color-fg-soft); font-size: 0.9rem; }

  @media (min-width: 560px) { .assets__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 900px) {
    .assets { grid-template-columns: 0.9fr 1.1fr; gap: 3.5rem; }
    .assets__grid { grid-template-rows: repeat(2, 1fr); height: 100%; }
  }
</style>
