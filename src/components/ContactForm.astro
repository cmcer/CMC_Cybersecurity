---
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const req = `(${t('contact.required')})`;
---
<form class="cform glass reveal" data-contact-form novalidate>
  <div class="cform__row">
    <div class="cform__field">
      <label for="cf-name">{t('contact.name')} <span class="cform__req">{req}</span></label>
      <input id="cf-name" name="name" type="text" autocomplete="name" required />
      <p class="cform__error" data-error></p>
    </div>
    <div class="cform__field">
      <label for="cf-email">{t('contact.email')} <span class="cform__req">{req}</span></label>
      <input id="cf-email" name="email" type="email" autocomplete="email" required />
      <p class="cform__error" data-error></p>
    </div>
  </div>

  <div class="cform__row">
    <div class="cform__field">
      <label for="cf-phone">{t('contact.phone')}</label>
      <input id="cf-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" />
      <p class="cform__error" data-error></p>
    </div>
    <div class="cform__field">
      <label for="cf-company">{t('contact.company')}</label>
      <input id="cf-company" name="company" type="text" autocomplete="organization" />
      <p class="cform__error" data-error></p>
    </div>
  </div>

  <div class="cform__field">
    <label for="cf-message">{t('contact.message')} <span class="cform__req">{req}</span></label>
    <textarea id="cf-message" name="message" rows="4" required></textarea>
    <p class="cform__error" data-error></p>
  </div>

  <button type="submit" class="btn btn-primary cform__submit">
    <span data-label>{t('contact.send')}</span>
    <Icon name="send" size={18} />
  </button>

  <p class="cform__success" data-success hidden>
    <Icon name="check" size={18} /> <span>{t('contact.success')}</span>
  </p>
</form>

<style>
  .cform { border-radius: var(--radius-xl); padding: clamp(1.5rem, 1rem + 2vw, 2.5rem); display: flex; flex-direction: column; gap: 1.25rem; }
  .cform__row { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  .cform__field { display: flex; flex-direction: column; gap: 0.45rem; }
  .cform label { font-size: 0.88rem; font-weight: 500; color: var(--color-fg-soft); }
  .cform__req { color: var(--color-fg-muted); font-weight: 400; font-size: 0.78rem; }
  .cform input, .cform textarea {
    width: 100%;
    min-height: 48px;
    background: rgba(5, 7, 14, 0.6);
    border: 1px solid var(--color-line-strong);
    border-radius: 7px;
    padding: 0.8rem 1rem;
    color: var(--color-fg);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .cform textarea { resize: vertical; min-height: 120px; }
  .cform input:focus, .cform textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(10, 145, 210, 0.16);
  }
  .cform input[aria-invalid='true'], .cform textarea[aria-invalid='true'] { border-color: var(--color-danger); }
  .cform__error { color: var(--color-danger); font-size: 0.8rem; min-height: 1rem; }
  .cform__error:empty { display: none; }
  .cform__submit { align-self: flex-start; }
  .cform__success {
    display: flex; align-items: center; gap: 0.5rem;
    color: var(--color-success); font-size: 0.95rem;
    padding: 0.85rem 1rem;
    background: rgba(52, 211, 153, 0.1);
    border: 1px solid rgba(52, 211, 153, 0.3);
    border-radius: 7px;
  }
  @media (min-width: 640px) { .cform__row { grid-template-columns: 1fr 1fr; } }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  if (form) {
    const isEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
    const messages = {
      required: form.closest('[lang="en"]') ? 'This field is required.' : 'Vui lòng điền thông tin này.',
      email: form.closest('[lang="en"]') ? 'Please enter a valid email address.' : 'Email chưa hợp lệ.',
    };

    const validateField = (el: HTMLInputElement | HTMLTextAreaElement) => {
      const wrap = el.closest('.cform__field');
      const errEl = wrap?.querySelector<HTMLElement>('[data-error]');
      let msg = '';
      if (el.hasAttribute('required') && !el.value.trim()) msg = messages.required;
      else if (el.type === 'email' && el.value && !isEmail(el.value)) msg = messages.email;
      if (errEl) errEl.textContent = msg;
      el.setAttribute('aria-invalid', msg ? 'true' : 'false');
      return !msg;
    };

    form.querySelectorAll<HTMLInputElement>('input, textarea').forEach((el) => {
      el.addEventListener('blur', () => validateField(el));
      el.addEventListener('input', () => {
        if (el.getAttribute('aria-invalid') === 'true') validateField(el);
      });
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fields = [...form.querySelectorAll<HTMLInputElement>('input, textarea')];
      let ok = true;
      let firstInvalid: HTMLElement | null = null;
      fields.forEach((el) => {
        const valid = validateField(el);
        if (!valid && !firstInvalid) firstInvalid = el;
        ok = ok && valid;
      });
      if (!ok) { firstInvalid && (firstInvalid as HTMLElement).focus(); return; }

      // Demo only: no backend. See README to wire Formspree / Hostinger PHP handler.
      const success = form.querySelector<HTMLElement>('[data-success]');
      const label = form.querySelector<HTMLElement>('[data-label]');
      const original = label?.textContent ?? '';
      if (label) label.textContent = '…';
      setTimeout(() => {
        form.reset();
        if (success) success.hidden = false;
        if (label) label.textContent = original;
        success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 600);
    });
  }
</script>
