---
interface Props {
  eyebrow?: string;
  title: string;
  sub?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, sub, align = 'center' } = Astro.props;
---
<div class:list={['sh', align === 'center' ? 'sh--center' : 'sh--left', 'reveal']}>
  {eyebrow && <span class="eyebrow sh__eyebrow">{eyebrow}</span>}
  <h2 class="sh__title">{title}</h2>
  {sub && <p class="sh__sub">{sub}</p>}
</div>

<style>
  .sh { display: flex; flex-direction: column; gap: 0.85rem; max-width: 62ch; }
  .sh--center { align-items: center; text-align: center; margin-inline: auto; }
  .sh__eyebrow { display: inline-flex; align-items: center; gap: 0.5rem; }
  .sh--center .sh__eyebrow::before,
  .sh--center .sh__eyebrow::after {
    content: ''; width: 26px; height: 1px; background: var(--color-primary); opacity: 0.5;
  }
  .sh__title { font-size: clamp(1.7rem, 1rem + 2.6vw, 2.7rem); }
  .sh__sub { color: var(--color-fg-soft); font-size: 1.04rem; }
</style>
