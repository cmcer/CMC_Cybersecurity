---
import { withBase } from '../i18n/utils';

interface Props {
  eyebrow: string;
  title: string;
  sub?: string;
  image?: string;
}
const { eyebrow, title, sub, image } = Astro.props;
---
<section class:list={['page-hero', image && 'page-hero--split']}>
  <div class="page-hero__grid grid-overlay" aria-hidden="true"></div>
  <div class="container-x page-hero__inner">
    <div class="page-hero__copy">
      <span class="eyebrow reveal">{eyebrow}</span>
      <h1 class="page-hero__title reveal" style="--reveal-delay:80ms">{title}</h1>
      {sub && <p class="page-hero__sub reveal" style="--reveal-delay:160ms">{sub}</p>}
    </div>
    {image && (
      <div class="page-hero__media reveal" style="--reveal-delay:160ms">
        <img src={withBase(image)} alt="" loading="eager" decoding="async" />
      </div>
    )}
  </div>
</section>

<style>
  .page-hero { position: relative; padding-top: 4.5rem; padding-bottom: 2.5rem; overflow: hidden; }
  .page-hero__grid { position: absolute; inset: 0; opacity: 0.5; }
  .page-hero__inner { position: relative; display: flex; flex-direction: column; gap: 1rem; }
  .page-hero__copy { display: flex; flex-direction: column; gap: 1rem; max-width: 60ch; }
  .page-hero__title { font-size: clamp(2.1rem, 1.2rem + 4vw, 3.4rem); }
  .page-hero__sub { color: var(--color-fg-soft); font-size: 1.1rem; max-width: 56ch; }

  .page-hero__media { width: 100%; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--color-line); box-shadow: 0 30px 70px -40px rgba(0, 0, 0, 0.7); }
  .page-hero__media img { width: 100%; height: 260px; object-fit: cover; display: block; }

  @media (min-width: 900px) {
    .page-hero--split .page-hero__inner { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 3rem; align-items: center; }
    .page-hero--split .page-hero__media img { height: 320px; }
  }
</style>
