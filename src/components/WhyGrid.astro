---
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getWhyChoose, certs } from '../data/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const items = getWhyChoose(lang);
---
<div class="why">
  <div class="why__grid">
    {items.map((it, i) => (
      <article class="why__card surface-card lift reveal" style={`--reveal-delay:${(i % 2) * 100}ms`}>
        <span class="why__icon"><Icon name={it.icon} size={26} /></span>
        <h3 class="why__title">{it.title}</h3>
        <p class="why__desc">{it.desc}</p>
      </article>
    ))}
  </div>

  <div class="why__certs reveal">
    <p class="why__certs-label">{t('section.certs.title')}</p>
    <div class="why__chips">
      {certs.map((c) => <span class="chip">{c}</span>)}
    </div>
  </div>
</div>

<style>
  .why__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .why__card { padding: 1.6rem; display: flex; flex-direction: column; gap: 0.7rem; }
  .why__icon {
    display: grid; place-items: center;
    width: 54px; height: 54px;
    border-radius: 8px;
    color: var(--color-primary-bright);
    background: linear-gradient(150deg, rgba(24, 200, 230, 0.16), rgba(10, 145, 210, 0.06));
    border: 1px solid rgba(24, 200, 230, 0.22);
  }
  .why__title { font-size: 1.18rem; }
  .why__desc { color: var(--color-fg-soft); font-size: 0.95rem; }

  .why__certs { margin-top: 2.5rem; text-align: center; }
  .why__certs-label {
    font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--color-fg-muted); margin-bottom: 1.1rem;
  }
  .why__chips { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; }

  @media (min-width: 640px) { .why__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .why__grid { grid-template-columns: repeat(4, 1fr); } }
</style>
