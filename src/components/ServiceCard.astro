---
import Icon from './Icon.astro';
interface Props {
  icon: string;
  title: string;
  desc: string;
  items?: string[];
  index?: number;
}
const { icon, title, desc, items = [], index = 0 } = Astro.props;
---
<article class="svc-card surface-card lift reveal" style={`--reveal-delay:${(index % 3) * 90}ms`}>
  <div class="svc-card__icon">
    <Icon name={icon} size={24} />
  </div>
  <h3 class="svc-card__title">{title}</h3>
  <p class="svc-card__desc">{desc}</p>
  {items.length > 0 && (
    <ul class="svc-card__items">
      {items.map((it) => (
        <li><Icon name="check" size={15} /> <span>{it}</span></li>
      ))}
    </ul>
  )}
  <span class="svc-card__glow" aria-hidden="true"></span>
</article>

<style>
  .svc-card {
    position: relative;
    padding: 1.75rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    height: 100%;
  }
  .svc-card__icon {
    display: grid; place-items: center;
    width: 52px; height: 52px;
    border-radius: 8px;
    color: var(--color-primary-bright);
    background: linear-gradient(150deg, rgba(10, 145, 210, 0.18), rgba(10, 145, 210, 0.03));
    border: 1px solid rgba(10, 145, 210, 0.25);
  }
  .svc-card__title { font-size: 1.22rem; }
  .svc-card__desc { color: var(--color-fg-soft); font-size: 0.96rem; }
  .svc-card__items { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-top: auto; padding-top: 0.5rem; }
  .svc-card__items li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; color: var(--color-fg-soft); }
  .svc-card__items li :global(svg) { color: var(--color-primary); flex: none; }
  .svc-card__glow {
    position: absolute; top: -40%; right: -30%;
    width: 220px; height: 220px;
    background: radial-gradient(circle, rgba(10, 145, 210, 0.16), transparent 70%);
    opacity: 0; transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .svc-card:hover .svc-card__glow { opacity: 1; }
</style>
