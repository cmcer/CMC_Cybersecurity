---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations, localePath, alternatePath, stripBase } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const nav = [
  { key: 'nav.services', path: '/services' },
  { key: 'nav.solutions', path: '/solutions' },
  { key: 'nav.about', path: '/about' },
  { key: 'nav.news', path: '/news' },
  { key: 'nav.careers', path: '/careers' },
  { key: 'nav.contact', path: '/contact' },
] as const;

const current = stripBase(Astro.url.pathname).replace(/^\/en/, '').replace(/\/$/, '') || '/';
const isActive = (p: string) => current === p;

const otherLang = lang === 'vi' ? 'en' : 'vi';
const switchHref = alternatePath(Astro.url, otherLang);
---
<header data-header class="site-header">
  <div class="container-x site-header__inner">
    <Logo />

    <nav class="site-nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={localePath(item.path, lang)}
          class:list={['site-nav__link', { 'is-active': isActive(item.path) }]}
        >
          {t(item.key as any)}
        </a>
      ))}
    </nav>

    <div class="site-header__actions">
      <a href={switchHref} class="lang-switch" aria-label={`Switch to ${otherLang === 'vi' ? 'Tiếng Việt' : 'English'}`}>
        <Icon name="globe" size={16} />
        <span>{otherLang.toUpperCase()}</span>
      </a>
      <a href={localePath('/contact', lang)} class="btn btn-primary btn-sm">{t('cta.contact')}</a>
      <button data-burger class="burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-nav">
        <Icon name="menu" size={24} />
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div data-mobile-nav id="mobile-nav" class="mobile-nav">
    <nav aria-label="Mobile">
      {nav.map((item) => (
        <a href={localePath(item.path, lang)} class:list={['mobile-nav__link', { 'is-active': isActive(item.path) }]}>
          <span>{t(item.key as any)}</span>
          <Icon name="chevron-right" size={18} />
        </a>
      ))}
    </nav>
    <div class="mobile-nav__footer">
      <a href={switchHref} class="btn btn-ghost"><Icon name="globe" size={16} /> {otherLang.toUpperCase()}</a>
      <a href={localePath('/contact', lang)} class="btn btn-primary">{t('cta.contact')}</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.35s ease, border-color 0.35s ease, backdrop-filter 0.35s ease;
    border-bottom: 1px solid transparent;
  }
  .site-header.is-scrolled {
    background: rgba(5, 7, 14, 0.78);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: var(--color-line);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 76px;
    gap: 1rem;
  }
  .site-nav { display: none; gap: 0.35rem; }
  .site-nav__link {
    position: relative;
    padding: 0.5rem 0.9rem;
    font-size: 0.93rem;
    font-weight: 500;
    color: var(--color-fg-soft);
    border-radius: 6px;
    transition: color 0.25s ease, background 0.25s ease;
  }
  .site-nav__link:hover { color: var(--color-fg); background: rgba(255, 255, 255, 0.04); }
  .site-nav__link.is-active { color: var(--color-primary-bright); }
  .site-nav__link.is-active::after {
    content: '';
    position: absolute;
    left: 0.9rem; right: 0.9rem; bottom: 2px; height: 2px;
    background: var(--color-primary);
    border-radius: 2px;
    box-shadow: 0 0 10px var(--color-primary);
  }

  .site-header__actions { display: flex; align-items: center; gap: 0.6rem; }
  .lang-switch {
    display: none;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.5rem 0.7rem;
    border-radius: 6px;
    border: 1px solid var(--color-line-strong);
    color: var(--color-fg-soft);
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .lang-switch:hover { color: var(--color-primary); border-color: var(--color-primary); }
  .btn-sm { padding: 0.6rem 1.1rem; min-height: 42px; font-size: 0.88rem; display: none; }

  .burger {
    display: inline-grid;
    place-items: center;
    width: 44px; height: 44px;
    border-radius: 6px;
    border: 1px solid var(--color-line-strong);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-fg);
    cursor: pointer;
  }

  .mobile-nav {
    position: fixed;
    inset: 76px 0 0 0;
    z-index: 99;
    background: rgba(5, 7, 14, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 1.5rem 1.25rem 2rem;
    transform: translateY(-12px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s var(--ease-out-expo);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .mobile-nav.is-open { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .mobile-nav__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0.5rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-fg);
    border-bottom: 1px solid var(--color-line);
  }
  .mobile-nav__link.is-active { color: var(--color-primary-bright); }
  .mobile-nav__footer { display: flex; gap: 0.75rem; margin-top: 1.5rem; }
  .mobile-nav__footer .btn { flex: 1; }

  @media (min-width: 1024px) {
    .site-nav { display: flex; }
    .lang-switch { display: inline-flex; }
    .btn-sm { display: inline-flex; }
    .burger { display: none; }
    .mobile-nav { display: none; }
  }
</style>
