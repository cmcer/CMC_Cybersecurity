---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getStats } from '../data/content';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const stats = getStats(lang);
---
<section class="statsband container-x">
  <div class="statsband__head reveal">
    <h2 class="statsband__title">{t('section.stats.title')}</h2>
    <p class="statsband__sub">{t('section.stats.sub')}</p>
  </div>
  <div class="statsband__grid">
    {stats.map((s, i) => (
      <div class="statsband__item reveal" style={`--reveal-delay:${i * 110}ms`}>
        <span class="statsband__value text-gradient"><span data-counter={s.value} data-suffix={s.suffix}>0{s.suffix}</span></span>
        <span class="statsband__label">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .statsband { padding-block: 3.5rem; }
  .statsband__head { text-align: center; max-width: 56ch; margin: 0 auto 2.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .statsband__title { font-size: clamp(1.6rem, 1rem + 2.4vw, 2.3rem); }
  .statsband__sub { color: var(--color-fg-soft); }

  .statsband__grid {
    display: grid; grid-template-columns: 1fr; gap: 1.25rem;
    border: 1px solid var(--color-line); border-radius: var(--radius-xl);
    background: linear-gradient(165deg, var(--color-surface), var(--color-bg-soft));
    padding: 2.5rem 1.5rem;
  }
  .statsband__item { text-align: center; display: flex; flex-direction: column; gap: 0.3rem; }
  .statsband__value { font-size: clamp(2.4rem, 1.5rem + 3vw, 3.4rem); font-weight: 800; line-height: 1; }
  .statsband__label { color: var(--color-fg-soft); font-size: 0.95rem; }

  @media (min-width: 760px) {
    .statsband__grid { grid-template-columns: repeat(3, 1fr); }
    .statsband__item:not(:last-child) { border-right: 1px solid var(--color-line); }
  }
</style>
