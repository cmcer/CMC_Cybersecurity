---
// Animated particle-network background (cyber HUD). Fixed, decorative, pointer-events: none.
---
<div class="cyber-bg" aria-hidden="true">
  <canvas data-particles></canvas>
  <div class="cyber-bg__grid grid-overlay"></div>
  <div class="cyber-bg__scan"></div>
</div>

<style>
  .cyber-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }
  .cyber-bg canvas { width: 100%; height: 100%; display: block; opacity: 0.6; }
  .cyber-bg__grid {
    position: absolute;
    inset: 0;
    opacity: 0.5;
  }
  .cyber-bg__scan {
    position: absolute;
    left: 0;
    right: 0;
    height: 140px;
    background: linear-gradient(180deg, transparent, rgba(10, 145, 210, 0.06), transparent);
    animation: scan 9s linear infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .cyber-bg__scan { display: none; }
    .cyber-bg canvas { opacity: 0.35; }
  }
</style>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const canvas = document.querySelector<HTMLCanvasElement>('[data-particles]');
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);
    let raf = 0;
    let running = true;

    interface P { x: number; y: number; vx: number; vy: number; }
    let pts: P[] = [];

    const density = () => {
      const area = w * h;
      const base = Math.round(area / 26000);
      return Math.max(28, Math.min(prefersReduced ? 36 : 90, base));
    };

    const seed = () => {
      pts = Array.from({ length: density() }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.32,
        vy: (Math.random() - 0.5) * 0.32,
      }));
    };

    const resize = () => {
      w = window.innerWidth;
      h = window.innerHeight;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      seed();
    };

    const draw = () => {
      ctx.clearRect(0, 0, w, h);
      const linkDist = 130;
      for (let i = 0; i < pts.length; i++) {
        const p = pts[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;

        for (let j = i + 1; j < pts.length; j++) {
          const q = pts[j];
          const dx = p.x - q.x, dy = p.y - q.y;
          const d = Math.hypot(dx, dy);
          if (d < linkDist) {
            const a = (1 - d / linkDist) * 0.4;
            ctx.strokeStyle = `rgba(45, 150, 215, ${a})`;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(q.x, q.y);
            ctx.stroke();
          }
        }
        ctx.fillStyle = 'rgba(63, 185, 240, 0.85)';
        ctx.beginPath();
        ctx.arc(p.x, p.y, 1.5, 0, Math.PI * 2);
        ctx.fill();
      }
      if (running) raf = requestAnimationFrame(draw);
    };

    const start = () => { if (!running) { running = true; draw(); } };
    const stop = () => { running = false; cancelAnimationFrame(raf); };

    resize();
    let rt: number;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = window.setTimeout(resize, 200);
    });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop(); else start();
    });

    if (prefersReduced) {
      // draw a single static frame
      draw();
      stop();
    } else {
      draw();
    }
  }
</script>
